    {
      "name": "Emails",
      "item": [
        {
          "name": "1. Inbound Email (Cloudflare Webhook)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const randomId = Math.floor(Math.random() * 1000000000);",
                  "pm.variables.set('dynamicMessageId', `<test-message-${randomId}@mail.example.com>`);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-webhook-secret",
                "value": "dev_webhook_secret_123",
                "description": "Must match the WEBHOOK_SECRET env variable on the server."
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messageId\": \"{{dynamicMessageId}}\",\n  \"from\": {\n    \"address\": \"jane.doe@example.com\",\n    \"name\": \"Jane Doe\"\n  },\n  \"to\": [\n    { \"address\": \"support@yourdomain.com\" }\n  ],\n  \"subject\": \"Feedback on new feature\",\n  \"text\": \"Hi support, I really love the new simplified mailbox UI! Great job.\",\n  \"html\": \"<p>Hi support, I really love the new simplified mailbox UI! <strong>Great job.</strong></p>\"\n}\n"
            },
            "url": {
              "raw": "{{baseUrl}}/api/emails",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "emails"
              ]
            },
            "description": "Public endpoint called by Cloudflare Email Routing when an email arrives at a configured address. Authenticated by the x-webhook-secret header, not a user session. Automatically deduplicates by messageId."
          },
          "response": []
        },
        {
          "name": "2. List Emails",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/emails?page=1&limit=50",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "emails"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Items per page (default: 50, max: 100)"
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Search by subject, sender address, or sender name",
                  "disabled": true
                },
                {
                  "key": "trashed",
                  "value": "true",
                  "description": "Filter by trashed emails only",
                  "disabled": true
                },
                {
                  "key": "starred",
                  "value": "true",
                  "description": "Filter by starred/saved emails only",
                  "disabled": true
                }
              ]
            },
            "description": "Returns a paginated list of all emails. Supports filtering by search, trashed, or starred. Each item includes isRead, isSaved and isTrashed flags specific to the currently logged-in user. Requires a valid session cookie."
          },
          "response": []
        },
        {
          "name": "3. Get Email by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/emails/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "emails",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<email-id>",
                  "description": "The email's cuid"
                }
              ]
            },
            "description": "Returns the full email including bodyHtml and bodyText. Also returns isRead and isSaved for the current user. Requires a valid session cookie."
          },
          "response": []
        },
        {
          "name": "4. Mark Email as Read",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"read\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/emails/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "emails",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<email-id>"
                }
              ]
            },
            "description": "Marks the email as read for the currently logged-in user only. Other team members are unaffected."
          },
          "response": []
        },
        {
          "name": "5. Mark Email as Unread",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"unread\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/emails/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "emails",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<email-id>"
                }
              ]
            },
            "description": "Marks the email as unread for the currently logged-in user only."
          },
          "response": []
        },
        {
          "name": "6. Save Email (Star)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"save\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/emails/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "emails",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<email-id>"
                }
              ]
            },
            "description": "Saves / stars the email for the currently logged-in user."
          },
          "response": []
        },
        {
          "name": "7. Unsave Email (Unstar)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"unsave\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/emails/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "emails",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<email-id>"
                }
              ]
            },
            "description": "Removes the saved/starred state for the currently logged-in user."
          },
          "response": []
        },
        {
          "name": "8. Trash Email",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"trash\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/emails/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "emails",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<email-id>"
                }
              ]
            }
          }
        },
        {
          "name": "9. Restore Email",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"restore\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/emails/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "emails",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<email-id>"
                }
              ]
            }
          }
        },
        {
          "name": "10. Send Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to\": \"recipient@example.com\",\n  \"subject\": \"Test Send\",\n  \"bodyText\": \"Hello from API\",\n  \"mailboxAddressId\": \"cuid_here\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/emails/send",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "emails",
                "send"
              ]
            }
          }
        }
      ],
      "description": "Core email endpoints. POST is public (called by Cloudflare). GET/PATCH require a valid session cookie."
    },
    {
      "name": "Mailbox Addresses",
      "item": [
