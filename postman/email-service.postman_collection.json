            "description": "Updates display details or toggles active status of the mailbox. Requires OWNER or ADMIN role."
          },
          "response": []
        },
        {
          "name": "4. Delete Mailbox Address",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/mailbox-addresses/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mailbox-addresses",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<mailbox-id>",
                  "description": "The mailbox address cuid"
                }
              ]
            },
            "description": "Deletes the mailbox address. If role is OWNER, it performs a hard delete (cascading emails). If ADMIN, it performs a soft delete (deactivates)."
          },
          "response": []
        }
      ],
      "description": "Manage inbound organization mailbox addresses. Requires OWNER or ADMIN role for modifications."
    },
