  "item": [
    {
      "name": "Auth & Setup",
      "item": [
        {
          "name": "1. Initial Setup (Create Owner)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"System\",\n  \"lastName\": \"Owner\",\n  \"email\": \"prashantnigam490@gmail.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/setup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "setup"
              ]
            },
            "description": "Used ONLY ONCE to initialize the database and create the root OWNER account. Will return 403 Forbidden if an owner already exists."
          },
          "response": []
        },
        {
          "name": "2. Register Member",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password12345\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Registers a standard user. By default, all users created through this endpoint are assigned the MEMBER role."
          },
          "response": []
        },
        {
          "name": "3. Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"prashantnigam490@gmail.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Authenticates the user and sets a secure, HTTP-only `auth_session` cookie."
          },
          "response": []
        },
        {
          "name": "4. Get Current User (/me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "Reads the HTTP-only session cookie (Postman sends this automatically if you just logged in) and returns the user's profile and current role."
          },
          "response": []
        },
        {
          "name": "5. Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            },
            "description": "Clears the secure, HTTP-only session cookie (`auth_session`) and deletes the active session from the database."
          },
          "response": []
        },
        {
          "name": "6. Request Password Reset (Forgot Password)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"prashantnigam490@gmail.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/forgot-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "forgot-password"
              ]
            },
            "description": "Requests a password reset token for the specified email address, generating a validation token in the database."
          },
          "response": []
        },
        {
          "name": "7. Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<insert_verification_token_here>\",\n  \"password\": \"newsecurepassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "reset-password"
              ]
            },
            "description": "Resets the user's password using the generated verification token."
          },
          "response": []
        }
      ]
    },
