# .env.example
# ==========================================
# DOCKER CONFIGURATION VARIABLES
# These must be defined first so that DATABASE_URL can use them.
# ==========================================

# Postgres
POSTGRES_USER=johndoe
POSTGRES_PASSWORD=randompassword
POSTGRES_DB=mydb
POSTGRES_SCHEMA=email_service

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=mydb
MYSQL_USER=johndoe
MYSQL_PASSWORD=randompassword

# ==========================================
# ACTIVE DATABASE CONFIGURATION
# Uncomment the block for the database you want to use.
# ==========================================

# Option 1: Local SQLite (No Docker)
# PRISMA_SCHEMA_PATH="./prisma/sqlite/schema.prisma"
# DATABASE_URL="file:./dev.db"

# Option 2: Postgres inside Docker Compose (Default)
PRISMA_SCHEMA_PATH="./prisma/postgres/schema.prisma"
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=${POSTGRES_SCHEMA}"

# Option 3: MySQL inside Docker Compose
# PRISMA_SCHEMA_PATH="./prisma/mysql/schema.prisma"
# DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@mysql:3306/${MYSQL_DATABASE}"

# ==========================================
# EMAIL WEBHOOK
# Shared secret between Cloudflare Email Routing and this app.
# Set the same value in your Cloudflare Worker / Email Route config.
# Generate with: openssl rand -hex 32
# ==========================================
WEBHOOK_SECRET="change_me_use_openssl_rand_hex_32"

# ==========================================
# OUTBOUND SMTP EMAIL CONFIGURATION
# Used by the application to send outbound emails.
# ==========================================
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false # false for port 587 (uses STARTTLS), true for port 465 (SSL/TLS)
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_NAME="Mailbox Platform"
SMTP_DRY_RUN=false
